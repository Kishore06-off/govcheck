# GovCheck AI - Environment Variables

# Groq API Configuration for LLM
GROQ_API_KEY=your_groq_api_key_here
GROQ_GENERATOR_MODEL=llama-3.3-70b-versatile

# Embedding Model Configuration
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# Directory Paths
CHROMA_PERSIST_DIR=./chroma_db
OUTPUT_DIR=./output
LOG_LEVEL=INFO
MAX_UPLOAD_MB=100

# CORS (set explicit origins in production)
CORS_ALLOW_ALL=false
CORS_ALLOW_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
ALLOW_PRIVATE_LINKS=false
API_AUTH_REQUIRED=false
API_KEY=change_me
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SEC=60

# Chunking / semantic chunking
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP=128
SEMANTIC_CHUNKING_ENABLED=true
SEMANTIC_SIM_THRESHOLD=0.70
SEMANTIC_MIN_TOKENS=128
FAST_TOKEN_COUNT=false
TOKEN_COUNT_CACHE_SIZE=20000

# Retrieval tuning
SEARCH_WEIGHT_ALPHA=0.7
RETRIEVAL_FETCH_MULTIPLIER=3
RETRIEVAL_CACHE_ENABLED=false
RETRIEVAL_CACHE_TTL_SEC=30
RETRIEVAL_CACHE_SIZE=256

# Optional cross-encoder re-ranking (downloads model on first use)
RERANK_ENABLE=false
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_CANDIDATE_MULTIPLIER=2

# Verification pass (filters unsupported requirements)
VERIFY_ENABLE=true
VERIFY_MIN_CONFIDENCE=0.80

# Ingestion performance/runtime behavior
INGEST_GC_BETWEEN_STAGES=true
DELTA_INGEST_ENABLED=true
